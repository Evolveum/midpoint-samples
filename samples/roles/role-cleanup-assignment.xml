    <inducement>
        <focusMappings>
            <mapping>
                <expression>
                    <script>
                        <code>return null</code>
                    </script>
                </expression>
                <target>
                    <path>assignment</path>
                    <set>
                        <additionalMappingSpecification>
                            <!-- place here the content of the mappingSpecification you want to address -->
                            <definitionObjectRef oid="4a86b950-575f-4923-90c6-bf04e6b7f9c4"  relation="org:default" type="c:ResourceType" />
                            <objectType>
                                <kind>account</kind>
                                <intent>user</intent>
                            </objectType>
                            <mappingName>group-import#1</mappingName>
                        </additionalMappingSpecification>
                    </set>
                </target>
            </mapping>
        </focusMappings>
    </inducement>
</role>
