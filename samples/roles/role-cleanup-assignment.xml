      oid="101d50da-af83-452d-83e1-bd28088c9ba9">
    <name>MAINTENANCE : clean up assignment from obsolete mapping</name>
<!--
 - - - sample data located in the assignment element on the related focus object - e.g. User
        <_metadata id="138">
            <storage>
                <createTimestamp>2026-03-20T10:04:48.545Z</createTimestamp>
                <creatorRef oid="00000000-0000-0000-0000-000000000002" relation="org:default" type="c:UserType" />
                <createChannel>http://midpoint.evolveum.com/xml/ns/public/common/channels-3#user</createChannel>
            </storage>
            <process>
                <requestTimestamp>2026-03-20T10:04:48.483Z</requestTimestamp>
                <requestorRef oid="00000000-0000-0000-0000-000000000002" relation="org:default" type="c:UserType" />
           </process>
            <provenance>
                <mappingSpecification>
                    <definitionObjectRef oid="4a86b950-575f-4923-90c6-bf04e6b7f9c4" relation="org:default" type="c:ResourceType" />
                    <objectType>
                        <kind>account</kind>
                        <intent>user</intent>
                    </objectType>
                    <mappingName>group-import#1</mappingName>
                </mappingSpecification>
            </provenance>
        </_metadata>
