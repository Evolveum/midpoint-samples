        </display>
        <displayOrder>100</displayOrder>
        <data>
            <sourceType>objectCollection</sourceType>
            <collection>
                <collectionRef oid="8494d5a9-5ce9-4795-813b-0e424b9e4d42" type="c:ObjectCollectionType"/>
            </collection>
        </data>
        <presentation>
            <dataField>
